{
  "name": "chatgpt-app-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Minimal hello-world ChatGPT app using the Apps SDK",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "node server.js",
